# OpenAI API key (required)
OPENAI_API_KEY=sk-...

# Model to use for all GPT calls
GPT_MODEL=gpt-5.4

# Token chunk size for document processing
# Smaller = more chunks + more API calls; larger = fewer calls but may hit context limits
CHUNK_SIZE=4000

# Maximum concurrent OpenAI requests at any one time
# Lower this if you hit rate limit errors
MAX_PARALLEL_REQUESTS=5
