# Webroot-level Apache rules.
#
# ErrorDocument routes any 404 below this directory (including nested
# subdirectories) to /404.php — our cute OverPinku-themed page. The path
# is absolute from docroot; do NOT include http(s):// or Apache treats
# it as a redirect instead of an internal sub-request.
#
# Nginx users — see README for the equivalent error_page directive.

ErrorDocument 404 /404.php
ErrorDocument 403 /403.php

# Deny direct HTTP access to files that exist at the webroot but are
# only ever meant to be used as includes — visitors hitting them get
# nothing useful, just a leak of "yes, this file exists." Forcing them
# through the 403 page is cleaner and consistent.
#
# globalVariables.php : require_once'd by index.php; outputs nothing on
#                       its own. No reason to expose it as a URL.
<Files "globalVariables.php">
    Require all denied
</Files>

